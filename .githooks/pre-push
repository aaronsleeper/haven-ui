#!/usr/bin/env bash
# Blocks `git push` when typecheck or structural conform gates fail.
# Playwright gates (conform:token, conform:visual) run in CI, not here.
# Bypass in genuine emergencies with `git push --no-verify` — not a habit.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "pre-push: typecheck"
pnpm typecheck

echo "pre-push: conform:fast"
pnpm --filter @haven/ui-react conform:fast

echo "pre-push: ok — pushing"
