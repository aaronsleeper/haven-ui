{
  "name": "@haven/ui-react",
  "version": "0.1.0",
  "private": true,
  "description": "React components that mirror @haven/design-system pattern-library HTML class-for-class. Populated mechanically by the ui-react-porter skill, one component at a time.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./assets/*": "./src/assets/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsx scripts/generate-markdoc-schemas.ts",
    "clean": "rm -rf .turbo schema"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@haven/design-system": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0"
  }
}
