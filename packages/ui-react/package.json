{
  "name": "@haven/ui-react",
  "version": "0.1.0",
  "private": true,
  "description": "React components that mirror @haven/design-system pattern-library HTML class-for-class. Populated mechanically by the ui-react-porter skill, one component at a time.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./assets/*": "./src/assets/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsx scripts/generate-markdoc-schemas.ts",
    "compose": "tsx scripts/compose.ts",
    "storybook": "storybook dev -p 5178 --no-open",
    "storybook:build": "storybook build -o storybook-static",
    "storybook:serve": "http-server storybook-static -p 5178 -s",
    "conform:manifest": "tsx tests/conform/manifest.ts",
    "conform:app-shell": "tsx tests/conform/app-shell.ts",
    "conform:css-family": "tsx tests/conform/css-family.ts",
    "conform:wireframe-completeness": "tsx tests/conform/wireframe-completeness.ts",
    "conform:token": "playwright test tests/conform/token.spec.ts",
    "conform:visual": "playwright test tests/conform/visual.spec.ts",
    "conform": "pnpm conform:manifest && pnpm conform:app-shell && pnpm conform:css-family && pnpm conform:wireframe-completeness && pnpm conform:token && pnpm conform:visual",
    "clean": "rm -rf .turbo schema storybook-static test-results playwright-report"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@haven/design-system": "workspace:*"
  },
  "devDependencies": {
    "@markdoc/markdoc": "^0.5.7",
    "@playwright/test": "^1.47.0",
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "http-server": "^14.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "vite": "^6.0.0"
  }
}
