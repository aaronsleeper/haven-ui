{
  "name": "@haven/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Haven tokens, semantic classes, and pattern-library HTML — the authoritative spec every React component mirrors 1:1",
  "type": "module",
  "exports": {
    "./styles": "./src/styles/main.css",
    "./styles/print": "./src/styles/print.css",
    "./data/*": "./src/data/*"
  },
  "files": [
    "src",
    "pattern-library"
  ],
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "glob": "^13.0.6",
    "preline": "^4.1.2",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.14.0",
    "vite": "^6.0.0",
    "vite-plugin-html-inject": "^1.1.2"
  }
}
