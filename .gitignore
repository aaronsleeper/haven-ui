node_modules/
dist/
.DS_Store
*.local

# Vite dev-server cache
.vite/
**/.vite/

# Turborepo
.turbo/

# TypeScript build info
**/tsconfig.tsbuildinfo

# FontAwesome Pro — local copy, not committed
**/vendor/fontawesome/
.gstack/

# Playwright run artifacts (reports, traces, screenshots of failures).
# Baselines at __screenshots__/ ARE committed — they're the spec.
test-results/
playwright-report/
storybook-static/

# GitHub Pages build output (assembled by scripts/build-pages.sh)
_site/

# Doc-emit spike generated output (regenerate: node spikes/doc-emit/emit.mjs)
packages/design-system/pattern-library/_docs-spike/
packages/design-system/pattern-library/_sot-spike/
packages/design-system/pattern-library/_reason-spike/

# Surface-emit standalone bundles — regenerable build output, served via
# handoff/ for /preview. Regenerate: bash tools/surface-emit/build-bundle.sh {sot|reason}
handoff/cena-sot/
handoff/cena-reasoning/

# sop-docx-emit.sh staging dirs (regenerable: re-run the wrapper)
# Holds resolver-rewritten markdown + _diagram-cache/ per SoP exemplar
handoff/*/_sop-staging-*/
